<UserControl x:Class="FileKakari.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Width="88"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" />
            <Button x:Name="SaveButton"
                    Width="88"
                    IsDefault="True"
                    Click="SaveButton_Click" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="ThemeLabel" Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <ComboBox x:Name="ThemeComboBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                      MinHeight="30" DisplayMemberPath="Text" SelectedValuePath="Value" />

            <TextBlock x:Name="LanguageLabel" Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <ComboBox x:Name="LanguageComboBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                      MinHeight="30" DisplayMemberPath="Text" SelectedValuePath="Value" />

            <CheckBox x:Name="ShowHiddenFilesCheckBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" />
            <CheckBox x:Name="ShowSystemFilesCheckBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12" />
            <CheckBox x:Name="SortFoldersFirstCheckBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12" />

            <TextBlock x:Name="PreviewPanePlacementLabel" Grid.Row="5" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <ComboBox x:Name="PreviewPanePlacementComboBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,12"
                      MinHeight="30" DisplayMemberPath="Text" SelectedValuePath="Value" />

            <TextBlock x:Name="FontFamilyLabel" Grid.Row="6" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <ComboBox x:Name="FontFamilyComboBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,12" MinHeight="30" />

            <TextBlock x:Name="FontSizeLabel" Grid.Row="7" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <TextBox x:Name="FontSizeBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,12"
                     MinHeight="30" VerticalContentAlignment="Center" />

            <TextBlock x:Name="RowHeightLabel" Grid.Row="8" Grid.Column="0" Margin="0,0,12,12"
                       VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
            <TextBox x:Name="RowHeightBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,12"
                     MinHeight="30" VerticalContentAlignment="Center" />

            <TextBlock x:Name="ColumnsLabel" Grid.Row="9" Grid.Column="0" Margin="0,0,12,0"
                       VerticalAlignment="Top" Foreground="{DynamicResource TextBrush}" />
            <WrapPanel Grid.Row="9" Grid.Column="1">
                <CheckBox x:Name="ColumnNameCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnModifiedAtCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnKindCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnSizeCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnExtensionCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnCreatedAtCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnAccessedAtCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnAttributesCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnFullPathCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnParentPathCheckBox" Margin="0,0,16,10" />
                <CheckBox x:Name="ColumnBaseNameCheckBox" Margin="0,0,16,10" />
            </WrapPanel>

            <StackPanel Grid.Row="10" Grid.Column="1" Margin="0,8,0,0">
                <CheckBox x:Name="AutoPlayVideoPreviewCheckBox" />
                <TextBlock x:Name="AutoPlayVideoPreviewDescriptionText"
                           Margin="24,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SubtleTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal"
                        HorizontalAlignment="Left" Margin="0,16,0,0">
                <Button x:Name="OpenSettingsFolderButton" Padding="10,4" Margin="0,0,10,0"
                        Click="OpenSettingsFolderButton_Click" />
                <Button x:Name="OpenThemesFolderButton" Padding="10,4"
                        Click="OpenThemesFolderButton_Click" />
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
