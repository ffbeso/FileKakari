<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="AppBackgroundColor">#F4F8F2</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ControlBackgroundColor">#FFFFFF</Color>
    <Color x:Key="ControlHoverColor">#EAF5E8</Color>
    <Color x:Key="ControlPressedColor">#D7EBD4</Color>
    <Color x:Key="ControlDisabledColor">#EEF2EC</Color>
    <Color x:Key="HeaderBackgroundColor">#E8F1E5</Color>
    <Color x:Key="HeaderHoverColor">#DCEBD8</Color>
    <Color x:Key="HeaderGripColor">#A7BBA2</Color>
    <Color x:Key="HeaderGripHoverColor">#7F9C78</Color>
    <Color x:Key="RowBackgroundColor">#FFFFFF</Color>
    <Color x:Key="RowHoverColor">#F0F7EE</Color>
    <Color x:Key="TabBackgroundColor">#D6E5D1</Color>
    <Color x:Key="TabSelectedBackgroundColor">#FFFFFF</Color>
    <Color x:Key="TabHoverBackgroundColor">#EDF7EA</Color>
    <Color x:Key="TabSeparatorColor">#B4C8AE</Color>
    <Color x:Key="TextColor">#1F2A1E</Color>
    <Color x:Key="SubtleTextColor">#5B6B57</Color>
    <Color x:Key="BorderColor">#C9D8C4</Color>
    <Color x:Key="GridLineColor">#E0E8DC</Color>
    <Color x:Key="SelectionBackgroundColor">#CFE8C9</Color>
    <Color x:Key="SelectionInactiveBackgroundColor">#E4EEE1</Color>
    <Color x:Key="SelectionTextColor">#10230F</Color>
    <Color x:Key="FolderIconColor">#B7851D</Color>
    <Color x:Key="FileIconColor">#2F7D4B</Color>
    <Color x:Key="ScrollBarTrackColor">#EDF3EA</Color>
    <Color x:Key="ScrollBarThumbColor">#AFC5A9</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#8EAD86</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#6E9468</Color>
    <Color x:Key="StatusBarBackgroundColor">#E8F1E5</Color>
    <Color x:Key="MenuIconColumnBackgroundColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{DynamicResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{DynamicResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="{DynamicResource ControlHoverColor}" />
    <SolidColorBrush x:Key="ControlPressedBrush" Color="{DynamicResource ControlPressedColor}" />
    <SolidColorBrush x:Key="ControlDisabledBrush" Color="{DynamicResource ControlDisabledColor}" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{DynamicResource HeaderBackgroundColor}" />
    <SolidColorBrush x:Key="HeaderHoverBrush" Color="{DynamicResource HeaderHoverColor}" />
    <SolidColorBrush x:Key="HeaderGripBrush" Color="{DynamicResource HeaderGripColor}" />
    <SolidColorBrush x:Key="HeaderGripHoverBrush" Color="{DynamicResource HeaderGripHoverColor}" />
    <SolidColorBrush x:Key="RowBackgroundBrush" Color="{DynamicResource RowBackgroundColor}" />
    <SolidColorBrush x:Key="RowHoverBrush" Color="{DynamicResource RowHoverColor}" />
    <SolidColorBrush x:Key="TabBackgroundBrush" Color="{DynamicResource TabBackgroundColor}" />
    <SolidColorBrush x:Key="TabSelectedBackgroundBrush" Color="{DynamicResource TabSelectedBackgroundColor}" />
    <SolidColorBrush x:Key="TabHoverBackgroundBrush" Color="{DynamicResource TabHoverBackgroundColor}" />
    <SolidColorBrush x:Key="TabSeparatorBrush" Color="{DynamicResource TabSeparatorColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="{DynamicResource SubtleTextColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
    <SolidColorBrush x:Key="GridLineBrush" Color="{DynamicResource GridLineColor}" />
    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="{DynamicResource SelectionBackgroundColor}" />
    <SolidColorBrush x:Key="SelectionInactiveBackgroundBrush" Color="{DynamicResource SelectionInactiveBackgroundColor}" />
    <SolidColorBrush x:Key="SelectionTextBrush" Color="{DynamicResource SelectionTextColor}" />
    <SolidColorBrush x:Key="FolderIconBrush" Color="{DynamicResource FolderIconColor}" />
    <SolidColorBrush x:Key="FileIconBrush" Color="{DynamicResource FileIconColor}" />
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="{DynamicResource ScrollBarTrackColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{DynamicResource ScrollBarThumbColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{DynamicResource ScrollBarThumbHoverColor}" />
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{DynamicResource ScrollBarThumbPressedColor}" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="{DynamicResource StatusBarBackgroundColor}" />

    <!-- Active/inactive pane chrome -->
    <SolidColorBrush x:Key="ActivePaneBorderBrush" Color="#8EAE95" />
    <SolidColorBrush x:Key="InactivePaneBorderBrush" Color="#DDE8D9" />
    <SolidColorBrush x:Key="ActivePaneAccentBrush" Color="#2F7D4B" />
    <SolidColorBrush x:Key="InactivePaneAccentBrush" Color="#DDE8D9" />
</ResourceDictionary>
