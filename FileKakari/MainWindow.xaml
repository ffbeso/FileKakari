<Window x:Class="FileKakari.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileKakari"
        mc:Ignorable="d"
        Title="FileKakari" Height="720" Width="1080"
        MinHeight="420" MinWidth="720">
    <Window.Resources>
        <local:PaneCountToColumnsConverter x:Key="PaneCountToColumnsConverter" />
        <DataTemplate x:Key="ListDisplayTemplate">
            <Grid Background="Transparent"
                  Height="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Tag="FileNameHitTarget" Width="18" Height="18" VerticalAlignment="Center" Margin="3,0,3,0">
                    <Image Width="16" Height="16" Source="{Binding Icon}" Stretch="Uniform" />
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               Width="18"
                               VerticalAlignment="Center"
                               Text="&#xE8B7;"
                               Foreground="{DynamicResource FolderIconBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDirectory}" Value="True" />
                                            <Condition Binding="{Binding Icon}" Value="{x:Null}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14"
                               Width="18"
                               VerticalAlignment="Center"
                               Text="&#xE8A5;"
                               Foreground="{DynamicResource FileIconBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDirectory}" Value="False" />
                                            <Condition Binding="{Binding Icon}" Value="{x:Null}" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           Tag="FileRenameHitTarget"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox Grid.Column="1"
                         Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="FileNameHitTarget"
                         VerticalContentAlignment="Center"
                         MinWidth="240"
                         Padding="4,0"
                         Background="{DynamicResource ControlBackgroundBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         CaretBrush="{DynamicResource TextBrush}"
                         Loaded="RenameTextBox_Loaded"
                         PreviewMouseDown="RenameTextBox_PreviewMouseDown"
                         MouseDown="RenameTextBox_MouseDown"
                         GotKeyboardFocus="RenameTextBox_GotKeyboardFocus"
                         PreviewKeyDown="RenameTextBox_PreviewKeyDown"
                         LostFocus="RenameTextBox_LostFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    <DockPanel Background="{DynamicResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TabControl x:Name="TabsControl"
                            Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="0,0,0,6"
                            AllowDrop="True"
                            PreviewMouseDown="TabsControl_PreviewMouseDown"
                            PreviewMouseLeftButtonDown="TabsControl_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="TabsControl_PreviewMouseLeftButtonUp"
                            PreviewMouseMove="TabsControl_PreviewMouseMove"
                            PreviewMouseRightButtonUp="TabsControl_PreviewMouseRightButtonUp"
                            DragOver="TabsControl_DragOver"
                            DragLeave="TabsControl_DragLeave"
                            Drop="TabsControl_Drop"
                            SelectionChanged="TabsControl_SelectionChanged">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border CornerRadius="3"
                                        Padding="4,1"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWorkspaceSessionTab}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsWorkspace}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ActivePaneAccentBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ActivePaneAccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="9"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="F" />
                                                <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWorkspace}" Value="True">
                                                        <Setter Property="Text" Value="W" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="&#xE72E;">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFolderLocked}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding InternalPageIconGlyph}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInternalPage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Grid MinWidth="24"
                                      Height="18"
                                      VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Header}"
                                               Tag="WorkspaceTabTitle"
                                               Margin="2,0"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Hidden" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="2,0"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Center"
                                             Background="{DynamicResource ControlBackgroundBrush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource ActivePaneAccentBrush}"
                                             CaretBrush="{DynamicResource TextBrush}"
                                             Loaded="WorkspaceTabRenameTextBox_Loaded"
                                             PreviewKeyDown="WorkspaceTabRenameTextBox_PreviewKeyDown"
                                             LostFocus="WorkspaceTabRenameTextBox_LostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>
                <StackPanel Grid.Row="0"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button x:Name="WorkspaceButton"
                            Width="32"
                            Height="28"
                            Padding="0"
                            Margin="4,0,0,0"
                            ToolTip="ワークスペース"
                            Content="💼"
                            Click="WorkspaceButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="WorkspaceButtonContextMenu" Opened="WorkspaceButtonContextMenu_Opened">
                                <MenuItem x:Name="WorkspaceButtonHeader" IsEnabled="False" Foreground="{DynamicResource SubtleTextBrush}" />
                                <Separator x:Name="WorkspaceButtonSeparator" />
                                <MenuItem x:Name="OpenWorkspaceMenuItem" Click="OpenWorkspaceMenuItem_Click" />
                                <MenuItem x:Name="SaveNewWorkspaceMenuItem" Click="SaveNewWorkspaceMenuItem_Click" />
                                <MenuItem x:Name="OverwriteWorkspaceMenuItem" Click="OverwriteWorkspaceMenuItem_Click" />
                                <MenuItem x:Name="SaveWorkspaceAsMenuItem" Click="SaveWorkspaceAsMenuItem_Click" />
                                <MenuItem x:Name="OpenWorkspaceJsonMenuItem" Click="OpenWorkspaceJsonMenuItem_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="InternalPageMenuButton"
                            Width="32"
                            Height="28"
                            Padding="0"
                            Margin="4,0,0,0"
                            ToolTip="内部ページ"
                            Content="&#xE712;"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            Click="InternalPageMenuButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="InternalPageContextMenu">
                                <MenuItem x:Name="InternalPageSettingsMenuItem"
                                          Click="InternalPageSettingsMenuItem_Click">
                                    <MenuItem.Icon>
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="&#xE713;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="InternalPageUserCommandEditorMenuItem"
                                          Click="InternalPageUserCommandEditorMenuItem_Click">
                                    <MenuItem.Icon>
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="&#xE70C;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="InternalPageLogViewerMenuItem"
                                          Click="InternalPageLogViewerMenuItem_Click">
                                    <MenuItem.Icon>
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="&#xE9D9;" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <Border x:Name="PathBarHost"
                        Grid.Row="1"
                        Grid.Column="1"
                        Height="28"
                        Margin="6,0,6,0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        Visibility="Collapsed"
                        PreviewMouseLeftButtonDown="PathBarHost_PreviewMouseLeftButtonDown">
                    <Grid>
                        <ScrollViewer x:Name="BreadcrumbScroller"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Disabled"
                                      VerticalAlignment="Center"
                                      Margin="4,0">
                            <StackPanel x:Name="BreadcrumbPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center" />
                        </ScrollViewer>
                        <TextBox x:Name="PathBox"
                                 Height="28"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="4,0"
                                 Visibility="Collapsed"
                                 KeyDown="PathBox_KeyDown"
                                 LostKeyboardFocus="PathBox_LostKeyboardFocus" />
                    </Grid>
                </Border>
                <Grid Grid.Row="1"
                      Grid.Column="2"
                      Height="28"
                      Visibility="Collapsed">
                    <TextBox x:Name="FilterBox"
                             VerticalContentAlignment="Center"
                             Padding="4,0"
                             TextChanged="FilterBox_TextChanged" />
                    <TextBlock x:Name="FilterPlaceholder"
                               Margin="8,0,4,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=FilterBox}" Value="" />
                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=FilterBox}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="WorkspacePaneRail"
                    Grid.Column="0"
                    Width="180"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="Collapsed">
                <ItemsControl x:Name="WorkspacePaneList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Padding="10,8"
                                    Margin="0"
                                    HorizontalContentAlignment="Stretch"
                                    Click="WorkspacePaneButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource FileKakariButtonStyle}">
                                        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SelectionInactiveBackgroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1"
                                               Margin="0,2,0,0"
                                               Text="{Binding CurrentPathSummary}"
                                               Foreground="{DynamicResource SubtleTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
            <Grid x:Name="PreviewLayoutGrid" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="PreviewSplitterRow" Height="0" />
                <RowDefinition x:Name="PreviewPaneRow" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="PreviewSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="PreviewPaneColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="ItemsListHost" Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
                <Border Grid.RowSpan="3"
                        Tag="True"
                        Style="{StaticResource FileKakariPaneChromeOverlayStyle}" />
                <Border MinHeight="44"
                        Padding="8,6"
                        Tag="True"
                        Style="{StaticResource FileKakariPaneHeaderBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                <Button x:Name="NormalPaneBackButton"
                                        Width="26"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="戻る"
                                        Content="⬅️"
                                        Click="BackButton_Click" />
                                <Button x:Name="NormalPaneForwardButton"
                                        Width="26"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="進む"
                                        Content="➡️"
                                        Click="ForwardButton_Click" />
                                <Button x:Name="NormalPaneUpButton"
                                        Width="26"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="親フォルダへ移動"
                                        Content="⬆️"
                                        Click="UpButton_Click" />
                                <Button x:Name="NormalPaneRefreshButton"
                                        Width="26"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,6,0"
                                        ToolTip="再読み込み"
                                        Content="🔄"
                                        Click="RefreshButton_Click" />
                                <Button x:Name="NormalPanePreviewButton"
                                        Width="28"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,6,0"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        Content="&#xE721;"
                                        ToolTip="プレビュー"
                                        Foreground="{DynamicResource TextBrush}"
                                        Loaded="PreviewToolbarButton_Loaded"
                                        Click="PreviewToggleButton_Click" />
                                <Button x:Name="NormalPanePlacesButton"
                                        Width="28"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="場所"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        Content="&#xE734;"
                                        Click="NormalPanePlacesButton_Click" />
                                <Button x:Name="NormalPaneViewModeButton"
                                        Width="28"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,6,0"
                                        ToolTip="表示モード"
                                        Content="▦"
                                        Click="ViewModeButton_Click" />
                                <Button x:Name="NormalPaneNewFolderButton"
                                        Width="28"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,2,0"
                                        ToolTip="新しいフォルダ"
                                        Content="📁"
                                        Click="NewFolderButton_Click" />
                                <Button x:Name="NormalPaneNewFileButton"
                                        Width="28"
                                        Height="24"
                                        Padding="0"
                                        Margin="0,0,6,0"
                                        ToolTip="新しいファイル"
                                        Content="📄"
                                        Click="NewFileButton_Click" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       x:Name="NormalPaneTitleText"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid Grid.Row="1"
                              Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <Border Height="26"
                                    Tag="True"
                                    Style="{StaticResource FileKakariPanePathBorderStyle}"
                                    PreviewMouseLeftButtonDown="NormalPanePathBar_PreviewMouseLeftButtonDown">
                                <Grid>
                                    <ScrollViewer x:Name="NormalPaneBreadcrumbScroller"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  Margin="4,0">
                                        <ItemsControl ItemsSource="{Binding NormalPaneBreadcrumbSegments, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      AlternationCount="1000">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="›"
                                                                   Margin="3,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource SubtleTextBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="0">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Button Content="{Binding Text}"
                                                                Tag="{Binding TargetPath}"
                                                                Padding="3,0"
                                                                MinHeight="22"
                                                                BorderThickness="0"
                                                                Background="Transparent"
                                                                PreviewMouseLeftButtonDown="BreadcrumbButton_PreviewMouseLeftButtonDown"
                                                                PreviewMouseMove="BreadcrumbButton_PreviewMouseMove"
                                                                Click="NormalPaneBreadcrumbButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource FileKakariButtonStyle}">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBox x:Name="NormalPanePathBox"
                                             Tag="PanePathBox"
                                             Visibility="Collapsed"
                                             BorderThickness="0"
                                             VerticalContentAlignment="Center"
                                             Padding="6,0"
                                             KeyDown="NormalPanePathBox_KeyDown"
                                             LostKeyboardFocus="NormalPanePathBox_LostKeyboardFocus" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="1"
                                    Height="26"
                                    Margin="6,0,0,0"
                                    Tag="True"
                                    Style="{StaticResource FileKakariPaneInputBorderStyle}">
                                <Grid>
                                <TextBox x:Name="NormalPaneFilterBox"
                                          Tag="PaneFilterBox"
                                          VerticalContentAlignment="Center"
                                          Padding="{DynamicResource PaneInputTextPadding}"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          ToolTip="フィルター"
                                          TextChanged="NormalPaneFilterBox_TextChanged" />
                                <TextBlock Text="フィルター"
                                           Margin="8,0,4,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Text, ElementName=NormalPaneFilterBox}" Value="" />
                                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=NormalPaneFilterBox}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            <ListView x:Name="ItemsList"
                      Grid.Row="1"
                      ItemsSource="{Binding ItemsView}"
                      SelectionMode="Extended"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True"
                      AllowDrop="True"
                      PreviewMouseDown="ItemsList_PreviewMouseDown"
                      PreviewMouseLeftButtonUp="ItemsList_PreviewMouseLeftButtonUp"
                      PreviewMouseRightButtonDown="ItemsList_PreviewMouseRightButtonDown"
                      PreviewMouseMove="ItemsList_PreviewMouseMove"
                      DragOver="ItemsList_DragOver"
                      DragLeave="ItemsList_DragLeave"
                      Drop="ItemsList_Drop"
                      MouseDoubleClick="ItemsList_MouseDoubleClick"
                      SelectionChanged="ItemsList_SelectionChanged"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="1"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      BorderThickness="0">
                <ListView.Resources>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListView.Resources>
                <ListView.View>
                    <GridView x:Name="DetailsGridView">
                    <GridViewColumn x:Name="NameColumn" Header="Name" Width="400">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Border Tag="FileNameHitTarget"
                                            Background="Transparent"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Stretch">
                                        <Grid Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,4,0">
                                            <Image Width="20" Height="20" Source="{Binding Icon}" Stretch="Uniform" />
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="15"
                                                       Width="22"
                                                       VerticalAlignment="Center"
                                                       Text="&#xE8B7;"
                                                       Foreground="{DynamicResource FolderIconBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsDirectory}" Value="True" />
                                                                    <Condition Binding="{Binding Icon}" Value="{x:Null}" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="15"
                                                       Width="22"
                                                       VerticalAlignment="Center"
                                                       Text="&#xE8A5;"
                                                       Foreground="{DynamicResource FileIconBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsDirectory}" Value="False" />
                                                                    <Condition Binding="{Binding Icon}" Value="{x:Null}" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   Tag="FileRenameHitTarget"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListViewItem}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                             Tag="FileNameHitTarget"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             MinWidth="240"
                                             Padding="8,0,4,0"
                                             Margin="22,0,0,0"
                                             Background="{DynamicResource ControlBackgroundBrush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             CaretBrush="{DynamicResource TextBrush}"
                                             Loaded="RenameTextBox_Loaded"
                                             PreviewMouseDown="RenameTextBox_PreviewMouseDown"
                                             MouseDown="RenameTextBox_MouseDown"
                                             GotKeyboardFocus="RenameTextBox_GotKeyboardFocus"
                                             PreviewKeyDown="RenameTextBox_PreviewKeyDown"
                                             LostFocus="RenameTextBox_LostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="KindColumn" Header="Type" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Kind}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="SizeColumn" Header="Size" Width="75">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeText}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ModifiedAtColumn" Header="Modified" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ModifiedAtText}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="CreatedAtColumn" Header="Created" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CreatedAtText}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="AccessedAtColumn" Header="Accessed" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AccessedAtText}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ExtensionColumn" Header="Extension" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Extension}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="AttributesColumn" Header="Attributes" Width="70">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AttributesText}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="FullPathColumn" Header="Full Path" Width="240">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullPath}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ParentPathColumn" Header="Parent Path" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ParentPath}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="BaseNameColumn" Header="Base Name" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BaseName}"
                                           HorizontalAlignment="Left" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <Canvas x:Name="RangeSelectionOverlay"
                    Grid.Row="1"
                    Background="Transparent"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Rectangle x:Name="RangeSelectionRectangle"
                           Fill="#335D9CEC"
                           Stroke="#CC5D9CEC"
                           StrokeThickness="1" />
            </Canvas>
            <Canvas x:Name="AutoScrollOverlay"
                    Grid.Row="1"
                    Background="Transparent"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <Canvas x:Name="AutoScrollMarker"
                        Width="20"
                        Height="20">
                    <Ellipse Width="16"
                             Height="16"
                             Canvas.Left="2"
                             Canvas.Top="2"
                             Fill="{DynamicResource PanelBackgroundBrush}"
                             Stroke="{DynamicResource TextBrush}"
                             StrokeThickness="1"
                             Opacity="0.92">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="4"
                                              ShadowDepth="0"
                                              Opacity="0.25" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <Line X1="10" Y1="4" X2="10" Y2="16"
                          Stroke="{DynamicResource TextBrush}"
                          StrokeThickness="1"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Opacity="0.85" />
                    <Line X1="4" Y1="10" X2="16" Y2="10"
                          Stroke="{DynamicResource TextBrush}"
                          StrokeThickness="1"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Opacity="0.85" />
                    <Ellipse Width="3"
                             Height="3"
                             Canvas.Left="8.5"
                             Canvas.Top="8.5"
                             Fill="{DynamicResource TextBrush}"
                             Opacity="0.9" />
                </Canvas>
            </Canvas>
            <Border Grid.Row="2"
                    MinHeight="24"
                    Padding="8,2"
                    Background="{DynamicResource StatusBarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <DockPanel LastChildFill="True">
                    <ProgressBar x:Name="LoadingProgress"
                                 DockPanel.Dock="Left"
                                 Width="120"
                                 Height="14"
                                 Margin="0,0,8,0"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed" />
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextBrush}" />
                </DockPanel>
            </Border>
            </Grid>
            <Grid x:Name="WorkspaceSplitGrid"
                  Grid.Row="0"
                  Visibility="Collapsed">
                <ItemsControl x:Name="WorkspaceSessionsHost"
                              ItemsSource="{Binding WorkspaceSessions, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:WorkspaceSession}">
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActiveSession}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <ItemsControl ItemsSource="{Binding PaneGroups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <local:WorkspaceSplitPanel LayoutRoot="{Binding DataContext.DisplayLayoutRoot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                       SplitRatioChanged="WorkspaceSplitPanel_SplitRatioChanged" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:FolderPane}">
                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,1,0"
                                    Background="{DynamicResource AppBackgroundBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.RowSpan="3"
                                            Tag="{Binding IsActive}"
                                            Style="{StaticResource FileKakariPaneChromeOverlayStyle}" />
                                    <Border Grid.Row="0"
                                             MinHeight="44"
                                             Padding="8,6"
                                             Tag="{Binding IsActive}"
                                             Style="{StaticResource FileKakariPaneHeaderBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Row 0: Sub-Tab Bar -->
                                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.ColumnSpan="2"
                                                        Tag="{Binding IsActive}"
                                                        Style="{StaticResource FileKakariPaneAccentLineStyle}" />

                                                <ListBox ItemsSource="{Binding Tabs}"
                                                         SelectedValue="{Binding SelectedTabId, Mode=TwoWay}"
                                                         SelectedValuePath="Id"
                                                         AllowDrop="True"
                                                         SelectionChanged="WorkspacePaneSubTabBar_SelectionChanged"
                                                         PreviewMouseDown="WorkspacePaneSubTabBar_PreviewMouseDown"
                                                         PreviewMouseMove="WorkspacePaneSubTabBar_PreviewMouseMove"
                                                         PreviewMouseWheel="WorkspacePaneSubTabBar_PreviewMouseWheel"
                                                         PreviewMouseRightButtonUp="WorkspacePaneSubTabBar_PreviewMouseRightButtonUp"
                                                         DragOver="WorkspacePaneSubTabBar_DragOver"
                                                         DragLeave="WorkspacePaneSubTabBar_DragLeave"
                                                         Drop="WorkspacePaneSubTabBar_Drop"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="Padding" Value="5,3" />
                                                            <Setter Property="Margin" Value="0,0,2,0" />
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Grid>
                                                                            <Border x:Name="Root"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                Background="{TemplateBinding Background}"
                                                                                Padding="{TemplateBinding Padding}"
                                                                                CornerRadius="3,3,0,0">
                                                                                <ContentPresenter />
                                                                            </Border>
                                                                            <Border x:Name="SelectedTabAccentLine"
                                                                                    Height="2"
                                                                                    VerticalAlignment="Bottom"
                                                                                    Background="Transparent"
                                                                                    IsHitTestVisible="False" />
                                                                        </Grid>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="SelectedTabAccentLine" Property="Background" Value="{DynamicResource InactivePaneAccentBrush}" />
                                                                                <Setter TargetName="SelectedTabAccentLine" Property="Opacity" Value="0.65" />
                                                                            </Trigger>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                                                                                    <Condition Binding="{Binding DataContext.IsActive, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter TargetName="SelectedTabAccentLine" Property="Background" Value="{DynamicResource ActivePaneAccentBrush}" />
                                                                                <Setter TargetName="SelectedTabAccentLine" Property="Opacity" Value="0.9" />
                                                                            </MultiDataTrigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource InactivePaneAccentBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                                                </Trigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                                                                        <Condition Binding="{Binding DataContext.IsActive, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ActivePaneAccentBrush}" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                                           FontSize="10"
                                                                           Text="&#xE72E;"
                                                                           Margin="0,0,3,0"
                                                                           Foreground="{DynamicResource SubtleTextBrush}"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFolderLocked}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding Header}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Margin="0,0,4,0"
                                                                           VerticalAlignment="Center"/>
                                                                <Button Content="×"
                                                                        Width="14"
                                                                        Height="14"
                                                                        Padding="0"
                                                                        FontSize="10"
                                                                        Background="Transparent"
                                                                        BorderThickness="0"
                                                                        Foreground="{DynamicResource SubtleTextBrush}"
                                                                        ToolTip="タブを閉じる"
                                                                        PreviewMouseLeftButtonDown="WorkspacePaneSubTabClose_PreviewMouseLeftButtonDown"
                                                                        Click="WorkspacePaneSubTabClose_Click"
                                                                        VerticalAlignment="Center">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource FileKakariButtonStyle}">
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Trigger.Setters>
                                                                                        <Setter Property="Foreground" Value="Red" />
                                                                                    </Trigger.Setters>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Width="20"
                                                            Height="20"
                                                            Padding="0"
                                                            Margin="2,0,0,0"
                                                            ToolTip="新しいサブタブ"
                                                            Content="＋"
                                                            AllowDrop="True"
                                                            DragOver="WorkspacePaneSubTabAddTarget_DragOver"
                                                            Drop="WorkspacePaneSubTabAddTarget_Drop"
                                                            Click="WorkspacePaneNewSubTabButton_Click" />
                                                </StackPanel>
                                            </Grid>

                                            <!-- Row 1: Action Toolbar -->
                                            <Border Grid.Row="1"
                                                    Tag="{Binding IsActive}"
                                                    Style="{StaticResource FileKakariPaneToolbarUnderlineStyle}">
                                                <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right"
                                                        Width="22"
                                                        Height="22"
                                                        Padding="0"
                                                        Margin="4,0,2,0"
                                                        ToolTip="ペイン操作"
                                                        Content="⋯"
                                                        Click="WorkspacePaneOperationsButton_Click">
                                                    <Button.ContextMenu>
                                                        <ContextMenu x:Name="WorkspacePaneOperationsContextMenu">
                                                            <MenuItem Header="右方向に分割" Click="WorkspacePaneSplitRightMenuItem_Click" />
                                                            <MenuItem Header="下方向に分割" Click="WorkspacePaneSplitDownMenuItem_Click" />
                                                            <Separator />
                                                            <MenuItem Header="ペインを閉じる" Click="WorkspacePaneCloseMenuItem_Click" />
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                    <Button Width="26"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="戻る"
                                                            Content="⬅️"
                                                            IsEnabled="{Binding CanGoBack}"
                                                            Click="WorkspacePaneBackButton_Click" />
                                                    <Button Width="26"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="進む"
                                                            Content="➡️"
                                                            IsEnabled="{Binding CanGoForward}"
                                                            Click="WorkspacePaneForwardButton_Click" />
                                                    <Button Width="26"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="親フォルダへ移動"
                                                            Content="⬆️"
                                                            IsEnabled="{Binding CanGoUp}"
                                                            Click="WorkspacePaneUpButton_Click" />
                                                     <Button Width="26"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,6,0"
                                                            ToolTip="再読み込み"
                                                            Content="🔄"
                                                            Click="WorkspacePaneRefreshButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,6,0"
                                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                            Content="&#xE721;"
                                                            ToolTip="プレビュー"
                                                            Foreground="{DynamicResource TextBrush}"
                                                            Loaded="PreviewToolbarButton_Loaded"
                                                            Click="PreviewToggleButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="場所"
                                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                            Content="&#xE734;"
                                                            Click="WorkspacePanePlacesButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,6,0"
                                                            ToolTip="表示モード"
                                                            Content="▦"
                                                            Click="WorkspacePaneViewModeButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="新しいフォルダ"
                                                            Content="📁"
                                                            Click="WorkspacePaneNewFolderButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,2,0"
                                                            ToolTip="新しいファイル"
                                                            Content="📄"
                                                            Click="WorkspacePaneNewFileButton_Click" />
                                                    <Button Width="28"
                                                            Height="24"
                                                            Padding="0"
                                                            Margin="0,0,6,0"
                                                            ToolTip="削除"
                                                            Content="🗑"
                                                            Click="WorkspacePaneDeleteButton_Click" />
                                                </StackPanel>
                                            </DockPanel>
                                            </Border>

                                            <!-- Row 2: Breadcrumb / Filter Bar -->
                                            <Grid Grid.Row="2"
                                                  Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="140" />
                                                </Grid.ColumnDefinitions>
                                                <Border Height="26"
                                                        Tag="{Binding IsActive}"
                                                        Style="{StaticResource FileKakariPanePathBorderStyle}"
                                                        PreviewMouseLeftButtonDown="WorkspacePanePathBar_PreviewMouseLeftButtonDown">
                                                    <Grid>
                                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                                                      VerticalScrollBarVisibility="Disabled"
                                                                      Margin="4,0">
                                                            <ItemsControl ItemsSource="{Binding BreadcrumbSegments}"
                                                                          AlternationCount="1000">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="›"
                                                                                       Margin="3,0"
                                                                                       VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource SubtleTextBrush}">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="0">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <Button Content="{Binding Text}"
                                                                                    Tag="{Binding TargetPath}"
                                                                                    Padding="3,0"
                                                                                    MinHeight="22"
                                                                                    BorderThickness="0"
                                                                                    Background="Transparent"
                                                                                    PreviewMouseLeftButtonDown="BreadcrumbButton_PreviewMouseLeftButtonDown"
                                                                                    PreviewMouseMove="BreadcrumbButton_PreviewMouseMove"
                                                                                    Click="WorkspacePaneBreadcrumbButton_Click">
                                                                                <Button.Style>
                                                                                    <Style TargetType="Button" BasedOn="{StaticResource FileKakariButtonStyle}">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                                                <Setter Property="Foreground" Value="{DynamicResource SubtleTextBrush}" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Button.Style>
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                        <TextBox Tag="PanePathBox"
                                                                 Visibility="Collapsed"
                                                                 BorderThickness="0"
                                                                 VerticalContentAlignment="Center"
                                                                 Padding="6,0"
                                                                 Text="{Binding CurrentPath, Mode=OneWay}"
                                                                 KeyDown="WorkspacePanePathBox_KeyDown"
                                                                 LostKeyboardFocus="WorkspacePanePathBox_LostKeyboardFocus"
                                                                 PreviewMouseLeftButtonDown="WorkspacePaneTextBox_PreviewMouseLeftButtonDown" />
                                                    </Grid>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        Height="26"
                                                        Margin="6,0,0,0"
                                                        Tag="{Binding IsActive}"
                                                        Style="{StaticResource FileKakariPaneInputBorderStyle}">
                                                    <Grid>
                                                    <TextBox x:Name="WorkspacePaneFilterTextBox"
                                                             Tag="PaneFilterBox"
                                                             VerticalContentAlignment="Center"
                                                             Padding="{DynamicResource PaneInputTextPadding}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             ToolTip="フィルター"
                                                             Text="{Binding ActiveTabState.FilterText, Mode=OneWay}"
                                                             TextChanged="WorkspacePaneFilterBox_TextChanged"
                                                             PreviewMouseLeftButtonDown="WorkspacePaneTextBox_PreviewMouseLeftButtonDown" />
                                                    <TextBlock Text="フィルター"
                                                               Margin="8,0,4,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource SubtleTextBrush}"
                                                               IsHitTestVisible="False">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding Text, ElementName=WorkspacePaneFilterTextBox}" Value="" />
                                                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=WorkspacePaneFilterTextBox}" Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <ListView ItemsSource="{Binding FileList.ItemsView}"
                                              Grid.Row="1"
                                              SelectionMode="Extended"
                                              SnapsToDevicePixels="True"
                                              UseLayoutRounding="True"
                                              AllowDrop="True"
                                              ButtonBase.Click="WorkspacePaneGridViewColumnHeader_Click"
                                              Loaded="WorkspacePaneFileList_Loaded"
                                              Unloaded="WorkspacePaneFileList_Unloaded"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              VirtualizingPanel.ScrollUnit="Pixel"
                                              VirtualizingPanel.CacheLength="1"
                                              VirtualizingPanel.CacheLengthUnit="Page"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              BorderThickness="0"
                                              PreviewMouseDown="WorkspacePaneFileList_PreviewMouseDown"
                                              PreviewMouseLeftButtonUp="WorkspacePaneFileList_PreviewMouseLeftButtonUp"
                                              PreviewMouseRightButtonDown="WorkspacePaneFileList_PreviewMouseRightButtonDown"
                                              PreviewMouseMove="WorkspacePaneFileList_PreviewMouseMove"
                                              MouseDoubleClick="WorkspacePaneFileList_MouseDoubleClick"
                                              SelectionChanged="WorkspacePaneFileList_SelectionChanged"
                                              ScrollViewer.ScrollChanged="WorkspacePaneFileList_ScrollChanged"
                                              DragOver="WorkspacePaneFileList_DragOver"
                                              DragLeave="WorkspacePaneFileList_DragLeave"
                                              Drop="WorkspacePaneFileList_Drop">
                                        <ListView.Resources>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Style>
                                        </ListView.Resources>
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Width="280"
                                                                CellTemplate="{StaticResource ListDisplayTemplate}">
                                                    <GridViewColumn.Header>
                                                        <TextBlock Text="{x:Static local:MainWindow.WorkspacePaneColumnNameText}" Tag="Name" />
                                                    </GridViewColumn.Header>
                                                </GridViewColumn>
                                                <GridViewColumn Width="100">
                                                    <GridViewColumn.Header>
                                                        <TextBlock Text="{x:Static local:MainWindow.WorkspacePaneColumnSizeText}" Tag="Size" />
                                                    </GridViewColumn.Header>
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding SizeText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Width="150">
                                                    <GridViewColumn.Header>
                                                        <TextBlock Text="{x:Static local:MainWindow.WorkspacePaneColumnModifiedText}" Tag="ModifiedAt" />
                                                    </GridViewColumn.Header>
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ModifiedAtText}" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Border Grid.Row="2"
                                            MinHeight="24"
                                            Padding="8,2"
                                            Background="{DynamicResource StatusBarBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,1,0,0">
                                        <DockPanel LastChildFill="True">
                                            <ProgressBar DockPanel.Dock="Left"
                                                         Width="96"
                                                         Height="14"
                                                         Margin="0,0,8,0"
                                                         IsIndeterminate="True">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FileList.IsLoading}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>
                                            <TextBlock Text="{Binding FileList.StatusText}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextBrush}" />
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            <GridSplitter x:Name="PreviewGridSplitter"
                           Grid.Row="1"
                           Grid.Column="0"
                           Height="5"
                           Width="Auto"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Background="{DynamicResource BorderBrush}"
                           Visibility="Collapsed" />
            <Border x:Name="PreviewPane"
                    Grid.Row="2"
                    Grid.Column="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    PreviewMouseWheel="PreviewPane_PreviewMouseWheel"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Padding="10,8"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <Button x:Name="PreviewCloseButton"
                                    DockPanel.Dock="Right"
                                    Width="28"
                                    Height="24"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                    Content="&#xE711;"
                                    Click="PreviewCloseButton_Click" />
                            <ProgressBar x:Name="PreviewLoadingBar"
                                         DockPanel.Dock="Right"
                                         Width="64"
                                         Height="12"
                                         Margin="8,0,0,0"
                                         IsIndeterminate="True"
                                         Visibility="Collapsed" />
                            <StackPanel>
                                <TextBlock x:Name="PreviewHeaderText"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="PreviewTitleText"
                                           Margin="0,2,0,0"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <TextBlock x:Name="PreviewMessageText"
                                   Margin="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SubtleTextBrush}" />
                        <Border x:Name="PreviewUnsupportedCard"
                                Margin="16"
                                Padding="16"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="PreviewUnsupportedTitleText"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="PreviewUnsupportedHintText"
                                           Margin="0,4,0,14"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SubtleTextBrush}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="PreviewInfoNameLabel" FontWeight="SemiBold" Margin="0,0,12,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoNameText" Grid.Column="1" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoExtensionLabel" Grid.Row="1" FontWeight="SemiBold" Margin="0,0,12,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoExtensionText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoSizeLabel" Grid.Row="2" FontWeight="SemiBold" Margin="0,0,12,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoSizeText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoModifiedLabel" Grid.Row="3" FontWeight="SemiBold" Margin="0,0,12,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoModifiedText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoPathLabel" Grid.Row="4" FontWeight="SemiBold" Margin="0,0,12,0" Foreground="{DynamicResource TextBrush}" />
                                    <TextBlock x:Name="PreviewInfoPathText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <TextBox x:Name="PreviewTextBox"
                                 Margin="8"
                                 Padding="8"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 Visibility="Collapsed" />
                        <Grid x:Name="PreviewImageScrollViewer"
                              Margin="8"
                              ClipToBounds="True"
                              Visibility="Collapsed">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"
                                   StretchDirection="DownOnly"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                        <Grid x:Name="PreviewVideoHost"
                              Margin="8"
                              ClipToBounds="True"
                              Opacity="0"
                              IsHitTestVisible="False"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <MediaElement x:Name="PreviewMediaElement"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          IsMuted="True"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          MediaOpened="PreviewMediaElement_MediaOpened"
                                          MediaEnded="PreviewMediaElement_MediaEnded"
                                          MediaFailed="PreviewMediaElement_MediaFailed" />
                            <StackPanel Grid.Row="1"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button x:Name="PreviewMediaPlayPauseButton"
                                        Width="36"
                                        Height="28"
                                        Padding="0"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        Content="&#xE768;"
                                        IsEnabled="False"
                                        Click="PreviewMediaPlayPauseButton_Click" />
                                <Button x:Name="PreviewMediaStopButton"
                                        Width="36"
                                        Height="28"
                                        Padding="0"
                                        Margin="6,0,0,0"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        Content="&#xE71A;"
                                        IsEnabled="False"
                                        Click="PreviewMediaStopButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            <ContentControl x:Name="InternalPageHost"
                            Grid.RowSpan="3"
                            Panel.ZIndex="10"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{DynamicResource AppBackgroundBrush}"
                            Visibility="Collapsed" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
